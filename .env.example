# Example environment variables for Docker Compose
# Copy this file to .env and fill in your actual values
# Docker Compose will automatically load variables from .env file

# Azure AD Service Principal Credentials (REQUIRED)
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Power BI Configuration (OPTIONAL - can be provided via config file)
# Comma-separated list of workspace IDs
POWERBI_WORKSPACE_IDS=workspace-id-1,workspace-id-2

# Comma-separated list of dataset IDs (optional)
POWERBI_DATASET_IDS=dataset-id-1,dataset-id-2

# Execution Configuration (OPTIONAL)
# Polling interval in seconds (default: 30)
POLL_INTERVAL=30

# Timeout in seconds (default: 3600 = 1 hour)
TIMEOUT=3600

# Maximum retry attempts (default: 3)
MAX_RETRIES=3

# Logging Configuration (OPTIONAL)
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Log file path (default: /app/logs/powerbi_refresh.log)
LOG_FILE=/app/logs/powerbi_refresh.log
